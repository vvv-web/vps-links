---
import Hero from '../components/Hero.astro';
import KnowledgeCard from '../components/KnowledgeCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { projects, vpsKnowledgePages } from '../data/projects';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="VPS Links"
	description="Публичная витрина VPS-проектов с brand-first hero, карточками сервисов и внутренней базой знаний."
	currentPath="/"
>
	<Hero projectCount={projects.length} knowledgeCount={vpsKnowledgePages.length} />

	<section class="section-block" id="projects" aria-labelledby="projects-heading">
		<div class="section-heading">
			<div class="section-heading__meta">
				<p class="section-kicker">Service catalog</p>
				<h2 id="projects-heading">Проекты и рабочие точки входа</h2>
				<p class="section-copy">
					Карточки ведут либо сразу в публичный сервис, либо на внутреннюю страницу проекта с
					кратким operational summary и ссылками на исходные документы.
				</p>
			</div>
			<div class="section-heading__tag">{projects.length} стартовых сервиса</div>
		</div>

		<div class="card-grid">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>

	<section class="section-block" id="knowledge" aria-labelledby="knowledge-heading">
		<div class="section-heading">
			<div class="section-heading__meta">
				<p class="section-kicker">Knowledge base</p>
				<h2 id="knowledge-heading">База знаний внутри витрины</h2>
				<p class="section-copy">
					Сначала короткая человеческая карта темы внутри GitHub Pages, а уже под ней ссылки на
					репозитории, README и runbook как на первоисточники.
				</p>
			</div>
			<div class="section-heading__tag">Внутренние страницы</div>
		</div>

		<div class="card-grid">
			{vpsKnowledgePages.map((page) => <KnowledgeCard page={page} />)}
		</div>
	</section>
</BaseLayout>
