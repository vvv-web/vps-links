---
import ProjectCard from '../components/ProjectCard.astro';
import { projects } from '../data/projects';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
	title="VPS Links"
	description="Стенд: ссылки на сервисы и документацию по проектам на VPS."
	currentPath="/"
>
	<section class="section-block section-block--dashboard" id="projects" aria-labelledby="projects-heading">
		<div class="section-heading">
			<div class="section-heading__meta">
				<p class="section-kicker">Сервисы</p>
				<h2 id="projects-heading">Проекты</h2>
			</div>
			<div class="section-heading__tag">{projects.length}</div>
		</div>

		<div class="card-grid">
			{projects.map((project) => <ProjectCard project={project} />)}
		</div>
	</section>
</BaseLayout>
