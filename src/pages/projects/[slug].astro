---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getProjectBySlug, getProjectSlugs, type ProjectRecord } from '../../data/projects';

export function getStaticPaths() {
	return getProjectSlugs().map((slug) => ({
		params: { slug },
		props: {
			project: getProjectBySlug(slug),
		},
	}));
}

const { project } = Astro.props as { project: ProjectRecord };
---

<BaseLayout
	title={project.title}
	description={project.description}
	eyebrow={project.vpsRole}
	pageTitle={project.title}
	pageLead={project.summary}
	currentPath={`/projects/${project.slug}/`}
	breadcrumbs={[
		{ label: 'Главная', href: '/' },
		{ label: 'Проекты', href: '/#projects' },
		{ label: project.title },
	]}
>
	<section class="project-detail-grid">
		<article class="page-card">
			<p class="card-kicker">{project.surface}</p>
			<h2>Назначение сервиса</h2>
			<p>{project.description}</p>

			<div class="project-meta">
				<div class="project-meta__item">
					<span class="project-meta__label">Контур</span>
					<span class="project-meta__value">{project.vpsRole}</span>
				</div>
				<div class="project-meta__item">
					<span class="project-meta__label">Публичный URL</span>
					<span class="project-meta__value">{project.publicUrl}</span>
				</div>
			</div>

			<div class="page-actions">
				<a href={project.publicUrl} target="_blank" rel="noreferrer">Открыть сервис</a>
				{
					project.repoUrl && (
						<a href={project.repoUrl} target="_blank" rel="noreferrer">
							Репозиторий
						</a>
					)
				}
			</div>
		</article>

		<div class="detail-panels">
			<aside class="detail-panel" id="docs">
				<h2>Документация</h2>
				<p class="detail-panel__lead">
					Сначала внутренняя wiki (runbook и контур), затем репозиторий и README целевой ветки. Ссылки —
					на момент сборки витрины; свежесть текста на wiki и в репо поддерживают люди, не этот сайт.
				</p>
				<ul class="link-list">
					{project.docsLinks.map((link) => (
						<li>
							<a href={link.href} target="_blank" rel="noreferrer">
								{link.label}
							</a>
						</li>
					))}
				</ul>
			</aside>

			<aside class="detail-panel">
				<h2>Заметки</h2>
				<ul class="note-list">
					{project.notes.map((note) => <li>{note}</li>)}
				</ul>
			</aside>

			{
				project.repoUrl && project.gitBranches && project.gitBranches.length > 0 && (
					<aside class="detail-panel">
						<h2>Ветки на GitHub</h2>
						<p class="muted detail-panel__lead">
							Сверено
							{project.gitBranchesAsOf ? ` ${project.gitBranchesAsOf}` : ''}. Ветка по умолчанию:{' '}
							<strong>{project.gitDefaultBranch ?? '—'}</strong>
							{project.vpsDeployBranch != null && (
								<>
									{' '}
									· деплой на VPS с ветки <strong>{project.vpsDeployBranch}</strong>
								</>
							)}
							.
						</p>
						<ul class="note-list">
							{project.gitBranches.map((b) => (
								<li>
									<code>{b}</code>
								</li>
							))}
						</ul>
					</aside>
				)
			}
		</div>
	</section>
</BaseLayout>
