---
interface Props {
	projectCount: number;
}

const { projectCount } = Astro.props;
---

<section class="hero hero--minimal" aria-labelledby="portal-hero-heading">
	<div class="hero__main">
		<div class="hero__stack">
			<p class="section-kicker">Портал</p>
			<h1 id="portal-hero-heading">Витрина сервисов на VPS</h1>
			<p class="hero__lead">
				Краткие карточки: стенд, публичный URL, ссылки на репозиторий и документацию.
			</p>

			<div class="hero__actions">
				<a class="button" href="#projects">Проекты</a>
			</div>

			<div class="hero__stats hero__stats--single" aria-label="Сводка портала">
				<div class="hero__stat">
					<strong>{projectCount}</strong>
					<span>проектов</span>
				</div>
			</div>
		</div>
	</div>
</section>
