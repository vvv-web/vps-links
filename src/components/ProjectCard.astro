---
import { getPrimaryDocLink, type ProjectRecord } from '../data/projects';
import { joinBasePath } from '../utils/paths';

interface Props {
	project: ProjectRecord;
}

const { project } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const primaryDocLink = getPrimaryDocLink(project);
const gitSummary =
	project.gitDefaultBranch != null
		? [
				`default: ${project.gitDefaultBranch}`,
				project.vpsDeployBranch != null ? `VPS deploy: ${project.vpsDeployBranch}` : null,
				project.gitBranches != null ? `${project.gitBranches.length} веток` : null,
			]
				.filter(Boolean)
				.join(' · ')
		: null;
---

<article class="project-card">
	<div class="card-topline">
		<div class="card-badge">
			<span class="card-badge__dot" aria-hidden="true"></span>
			<span>{project.vpsRole}</span>
		</div>
		<span class="muted">{project.surface}</span>
	</div>

	<h3>{project.title}</h3>
	<p>{project.description}</p>

	<div class="card-meta">
		<div class="card-meta__item">
			<span class="card-meta__label">Роль</span>
			<span class="card-meta__value">{project.surface}</span>
		</div>
		<div class="card-meta__item">
			<span class="card-meta__label">Доки</span>
			<span class="card-meta__value">{project.docsLinks.length} ссылки</span>
		</div>
		{
			gitSummary && (
				<div class="card-meta__item">
					<span class="card-meta__label">GitHub</span>
					<span class="card-meta__value">{gitSummary}</span>
				</div>
			)
		}
	</div>

	<div class="card-actions">
		<a href={project.publicUrl} target="_blank" rel="noreferrer">Открыть сервис</a>
		{
			primaryDocLink && (
				<a href={primaryDocLink.href} target="_blank" rel="noreferrer">
					Документация
				</a>
			)
		}
		<a href={joinBasePath(baseUrl, `projects/${project.slug}/`)}>О проекте</a>
	</div>
</article>
