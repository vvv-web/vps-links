---
import { getPrimaryDocLink, type ProjectRecord } from '../data/projects';
import { joinBasePath } from '../utils/paths';

interface Props {
	project: ProjectRecord;
}

const { project } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const primaryDocLink = getPrimaryDocLink(project);
---

<article class="project-card">
	<div class="card-topline">
		<div class="card-badge">
			<span class="card-badge__dot" aria-hidden="true"></span>
			<span>{project.vpsRole}</span>
		</div>
		<span class="muted">{project.surface}</span>
	</div>

	<h3>{project.title}</h3>
	<p>{project.summary}</p>

	<div class="card-actions">
		<a href={project.publicUrl} target="_blank" rel="noreferrer">Открыть сервис</a>
		{
			primaryDocLink && (
				<a href={primaryDocLink.href} target="_blank" rel="noreferrer">
					Документация
				</a>
			)
		}
		<a href={joinBasePath(baseUrl, `projects/${project.slug}/`)}>О проекте</a>
	</div>
</article>
