---
import { joinBasePath } from '../utils/paths';

const baseUrl = import.meta.env.BASE_URL;
---

<footer class="site-footer">
	<div>
		<p class="card-kicker">О сайте</p>
		<h2 class="site-footer__title">Статическая витрина</h2>
		<p class="section-copy">
			Только публичные ссылки и текст. Данные проектов — в файле <code>src/data/projects.ts</code>,
			страницы знаний — в <code>src/pages/knowledge/</code>.
		</p>
	</div>

	<div class="site-footer__links">
		<a href="https://github.com/vvv-web" target="_blank" rel="noreferrer">GitHub</a>
		<a href="https://github.com/vvv-web/vps-links" target="_blank" rel="noreferrer">Репозиторий витрины</a>
		<a href={joinBasePath(baseUrl, 'knowledge/deploy/')}>Развёртывание</a>
	</div>
</footer>
